# Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Database
DATABASE_URL=postgresql+asyncpg://visa:visa@postgres:5432/visa_bot
DATABASE_URL_SYNC=postgresql://visa:visa@postgres:5432/visa_bot

# Redis
REDIS_URL=redis://redis:6379/0

# Encryption key for session storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
