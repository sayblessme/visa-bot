# Monitoring defaults
MONITOR_INTERVAL_MIN=60
MONITOR_INTERVAL_MAX=180
MONITOR_JITTER=15

# Slot dedup window (minutes)
SLOT_DEDUP_MINUTES=30

# Logging
LOG_LEVEL=INFO
